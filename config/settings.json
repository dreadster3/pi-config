{
  "defaultModel": "minimax-m3",
  "defaultProvider": "litellm",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": false,
  "lastChangelogVersion": "0.80.3",
  "packages": [
    {
      "source": "npm:pi-subagents",
      "prompts": ["-prompts/review-loop.md"]
    },
    "git:github.com/nicobailon/visual-explainer@8f1d0e38ab0f265632a31d2fd032f7b730c98c15",
    "npm:context-mode",
    "npm:@ollama/pi-web-search",
    "npm:@plannotator/pi-extension",
    "git:github.com/dreadster3/pi-config",
    "npm:@juicesharp/rpiv-ask-user-question@v1.19.1",
    "npm:@juicesharp/rpiv-todo@v1.19.1",
    {
      "skills": [
        "skills/algorithmic-art",
        "skills/skill-creator",
        "skills/pdf",
        "skills/webapp-testing",
        "skills/theme-factory",
        "skills/xlsx",
        "skills/pptx",
        "skills/docx"
      ],
      "source": "git:github.com/anthropics/skills"
    },
    {
      "skills": ["skills/opensrc"],
      "source": "git:github.com/vercel-labs/opensrc@v0.7.2"
    },
    {
      "skills": ["skills/engineering/tdd"],
      "source": "git:github.com/mattpocock/skills@694fa30311e02c2639942308513555e61ee84a6f"
    },
    "npm:pi-mcp-adapter",
    "git:github.com/dreadster3/kilo-pi-provider@feat/kilo-apikey-env-var-syntax",
    "npm:pi-provider-litellm@1.2.8"
  ],
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "fallbackModels": ["litellm/qwen3.5"],
        "model": "litellm/minimax-m3",
        "thinking": "medium"
      },
      "delegate": {
        "fallbackModels": ["litellm/deepseek-v4-pro"],
        "model": "litellm/deepseek-v4-flash"
      },
      "oracle": {
        "fallbackModels": ["litellm/deepseek-v4-pro"],
        "model": "litellm/qwen3.7-max",
        "thinking": "high"
      },
      "planner": {
        "fallbackModels": ["litellm/glm-5.2", "litellm/qwen3.7-max"],
        "model": "litellm/deepseek-v4-pro",
        "thinking": "high"
      },
      "researcher": {
        "fallbackModels": ["litellm/deepseek-v4-flash"],
        "model": "litellm/kimi-k2.6",
        "thinking": "medium"
      },
      "reviewer": {
        "fallbackModels": ["litellm/qwen3.7-max", "litellm/deepseek-v4-pro"],
        "model": "litellm/glm-5.2",
        "thinking": "high"
      },
      "scout": {
        "fallbackModels": ["litellm/mimo-v2.5"],
        "model": "litellm/deepseek-v4-flash",
        "thinking": "low"
      },
      "worker": {
        "fallbackModels": [
          "litellm/deepseek-v4-pro",
          "litellm/deepseek-v4-pro"
        ],
        "model": "litellm/minimax-m3",
        "thinking": "high"
      }
    }
  },
  "theme": "catppuccin-mocha"
}
